require "base64"

default_platform(:ios)

# ─── iOS ────────────────────────────────────────────────────────────────────

platform :ios do
  # Build a simulator debug build (no signing) — used for PRs
  lane :build_debug do
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      skip_codesigning: true,
      skip_archive: true,
      skip_package_ipa: true,
    )
  end

  # Build release IPA and upload to TestFlight — used on main branch pushes
  lane :beta do
    # App Store Connect API key (no 2FA hassles)
    api_key = app_store_connect_api_key(
      key_id:      ENV.fetch("APPLE_API_KEY_ID"),
      issuer_id:   ENV.fetch("APPLE_API_ISSUER"),
      key_content: Base64.decode64(ENV.fetch("APPLE_API_KEY_BASE64")),
      is_key_content_base64: false,
    )

    # Use the GitHub Actions run number as the build number (always increasing)
    increment_build_number(
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", "1"),
      xcodeproj: "ios/App/App.xcodeproj",
    )

    build_app(
      workspace:     "ios/App/App.xcworkspace",
      scheme:        "App",
      configuration: "Release",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
